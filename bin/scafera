#!/usr/bin/env php
<?php

declare(strict_types=1);

$projectDir = dirname(__DIR__, 4);
if (!is_file($projectDir . '/vendor/autoload_runtime.php')) {
    $projectDir = getcwd();
}

require_once dirname(__DIR__) . '/src/Bootstrap.php';
\Scafera\Kernel\Bootstrap::init($projectDir);

require $projectDir . '/vendor/autoload_runtime.php';

return fn(array $context) => new \Scafera\Kernel\Console\ScaferaApplication(
    new \Scafera\Kernel\ScaferaKernel($context['APP_ENV'], (bool) $context['APP_DEBUG'], $projectDir)
);
