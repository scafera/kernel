{
    "name": "scafera/kernel",
    "description": "Kernel package for the Scafera framework",
    "type": "library",
    "license": "MIT",
    "keywords": ["scafera", "framework", "kernel", "php"],
    "homepage": "https://github.com/scafera/kernel",
    "support": {
        "issues": "https://github.com/scafera/kernel/issues",
        "source": "https://github.com/scafera/kernel"
    },
    "require": {
        "php": ">=8.4",
        "symfony/console": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Scafera\\Kernel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Scafera\\Kernel\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/scafera"],
    "extra": {
        "scafera-scaffold": {
            "files": {
                "config/config.example.yaml": "support/scaffold/config/config.example.yaml",
                "index.php": "support/scaffold/public/index.php"
            },
            "initial-files": {
                "config/config.yaml": "support/scaffold/config/config.example.yaml"
            }
        }
    }
}
