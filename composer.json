{
    "name": "scafera/kernel",
    "description": "Kernel package for the Scafera framework",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Scafera\\Kernel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Scafera\\Kernel\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/scafera"]
}
